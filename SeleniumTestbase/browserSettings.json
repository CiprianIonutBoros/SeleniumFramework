{
  "baseUrl": "https://www.saucedemo.com/",

  "browsers": {
    "chrome": {
      "headless": {
        "debug": false,
        "server": true
      },
      "windowSize": "1920,1080",
      "acceptInsecureCertificates": true,
      "arguments": [
        "--disable-search-engine-choice-screen",
        "--disable-extensions",
        "--disable-popup-blocking",
        "--disable-notifications",
        "--blink-settings=imagesEnabled=false"
      ]
    },

    "firefox": {
      "headless": {
        "debug": false,
        "server": true
      },
      "windowSize": "1920,1080",
      "acceptInsecureCertificates": true,
      "arguments": [
        "-private",
        "--disable-popup-blocking",
        "--disable-notifications"
      ]
    },

    "edge": {
      "headless": {
        "debug": false,
        "server": true
      },
      "windowSize": "1920,1080",
      "acceptInsecureCertificates": true,
      "arguments": [
        "--disable-extensions",
        "--disable-popup-blocking",
        "--disable-notifications",
        "--blink-settings=imagesEnabled=false"
      ]
    }
  },

  "timeouts": {
    "implicitMs": 0,
    "pageLoadMs": 60000
  }
}